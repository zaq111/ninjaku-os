#!/usr/bin/env python3
import sys
import json
from pathlib import Path

sys.path.insert(0, "/opt/ninjaku")

from lib.modules import execute, load_modules
from core.audit import list_logs

VERSION = "1.0-alpha"

def print_header():
    print("Ninjaku OS Router")
    print(f"Version: {VERSION}")
    print()

def cmd_status():
    s = execute('system', 'status')
    print_header()
    print(f"Hostname : {s.get('hostname','')}")
    print(f"Kernel   : {s.get('kernel','')}")
    print(f"Uptime   : {s.get('uptime','')}")
    print()
    print("Interfaces:")
    print(s.get("ip", ""))
    print()
    failed = s.get("failed_units", "").strip()
    if failed:
        print("Failed units:")
        print(failed)
    else:
        print("Failed units: none")

def cmd_status_json():
    print(json.dumps(execute('system', 'status'), indent=2))





def cmd_firewall():
    print_header()
    fw = execute("firewall", "status")
    print(f"IPv4 Forward : {fw.get('ip_forward', '')}")
    print(f"NFT OK       : {fw.get('nft_ok', '')}")
    print()
    print("Ruleset:")
    rules = fw.get("nft_ruleset", "")
    print(rules if rules else "(empty)")

def cmd_network():
    print_header()
    n = execute("network", "status")
    print("Interfaces:")
    print(n.get("interfaces", ""))
    print()
    print("Routes:")
    print(n.get("routes", ""))
    print()
    print("DNS:")
    print(n.get("dns", ""))

def cmd_modules():
    print_header()
    mods = load_modules()
    if not mods:
        print("No modules loaded.")
        return

    print("Loaded modules:")
    for name, mod in sorted(mods.items()):
        version = getattr(mod, "VERSION", "-")
        display = getattr(mod, "NAME", name)
        print(f"  {display:<16} {version}")

def cmd_audit():
    print_header()
    rows = list_logs(20)
    if not rows:
        print("No audit logs.")
        return
    for row in rows:
        id_, ts, actor, action, detail = row
        print(f"{id_:>4}  {ts}  {actor:<8}  {action:<16}  {detail}")

def cmd_help():
    print_header()
    print("Usage:")
    print("  ninjaku status")
    print("  ninjaku status")
    print("  ninjaku status --json")
    print("  ninjaku audit")
    print("  ninjaku modules")
    print("  ninjaku network")
    print("  ninjaku firewall")
    print("  ninjaku help")

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("help", "-h", "--help"):
        cmd_help()
        return

    if args[0] == "status":
        if len(args) > 1 and args[1] == "--json":
            cmd_status_json()
        else:
            cmd_status()
        return

    if args[0] == "audit":
        cmd_audit()
        return

    if args[0] == "modules":
        cmd_modules()
        return

    if args[0] == "network":
        cmd_network()
        return

    if args[0] == "firewall":
        cmd_firewall()
        return

    print(f"Unknown command: {args[0]}")
    print("Run: ninjaku help")
    sys.exit(1)

if __name__ == "__main__":
    main()
