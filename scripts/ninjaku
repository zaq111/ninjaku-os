#!/usr/bin/env python3
import sys
import json
from pathlib import Path

sys.path.insert(0, "/opt/ninjaku")

from lib.modules import execute, load_modules
from lib.settings import list_all, set as set_setting
from core.audit import list_logs

VERSION = "1.0-alpha"

def print_header():
    print("Ninjaku OS Router")
    print(f"Version: {VERSION}")
    print()

def cmd_status():
    s = execute('system', 'status')
    print_header()
    print(f"Hostname : {s.get('hostname','')}")
    print(f"Kernel   : {s.get('kernel','')}")
    print(f"Uptime   : {s.get('uptime','')}")
    print()
    print("Interfaces:")
    print(s.get("ip", ""))
    print()
    failed = s.get("failed_units", "").strip()
    if failed:
        print("Failed units:")
        print(failed)
    else:
        print("Failed units: none")

def cmd_status_json():
    print(json.dumps(execute('system', 'status'), indent=2))










def cmd_profiles():
    print_header()
    r = execute("profiles", "status")
    profiles = r.get("profiles", [])

    print("Profiles:")
    for p in profiles:
        print(f"  {p.get('name'):<10} {p.get('description')}")

def cmd_devices(args=None):
    args = args or []
    print_header()

    if args and args[0] == "sync":
        r = execute("devices", "sync")
        print("Devices sync:", "OK" if r.get("ok") else "FAILED")
        print(f"Lease count : {r.get('count', 0)}")
        return

    if args and args[0] in ("set-alias", "set-notes", "set-profile"):
        if len(args) < 3:
            print(f"Usage: ninjaku devices {args[0]} <mac> <value>")
            return
        r = execute("devices", args[0], mac=args[1], value=" ".join(args[2:]))
        print("Update:", "OK" if r.get("ok") else "FAILED")
        if not r.get("ok"):
            print(r.get("error", "unknown error"))
        else:
            print(f"{r.get('mac')} {r.get('field')} = {r.get('value')}")
        return

    d = execute("devices", "status")
    devices = d.get("devices", [])

    print(f"Devices: {d.get('count', 0)}")
    print()

    if not devices:
        print("(empty)")
        return

    print(f"{'IP':<16} {'MAC':<18} {'HOSTNAME':<18} {'ALIAS':<16} {'PROFILE':<10} {'SEEN'}")
    for dev in devices:
        print(
            f"{dev.get('ip',''):<16} "
            f"{dev.get('mac',''):<18} "
            f"{dev.get('hostname',''):<18} "
            f"{dev.get('alias',''):<16} "
            f"{dev.get('profile',''):<10} "
            f"{dev.get('seen_count','')}"
        )

def cmd_config(args):
    print_header()

    if not args or args[0] == "list":
        rows = list_all()
        if not rows:
            print("No settings.")
            return
        for k, v in rows:
            print(f"{k:<24} {v}")
        return

    if args[0] == "set" and len(args) >= 3:
        key = args[1]
        value = " ".join(args[2:])
        set_setting(key, value)
        print(f"Set {key} = {value}")
        return

    print("Usage:")
    print("  ninjaku config list")
    print("  ninjaku config set <key> <value>")

def cmd_dhcp(subcmd="status"):
    print_header()

    if subcmd == "start":
        r = execute("dhcp", "start")
        print("DHCP start:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "stop":
        r = execute("dhcp", "stop")
        print("DHCP stop:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    d = execute("dhcp", "status")
    print(f"Service : {d.get('service')}")
    print(f"Enabled : {d.get('enabled')}")
    print()
    print("Config:")
    print(d.get("config") or "(missing)")
    print()
    print("Leases:")
    print(d.get("leases") or "(empty)")

def cmd_router(subcmd="status"):
    print_header()

    if subcmd == "lan-up":
        r = execute("router", "lan-up")
        print("LAN up:", "OK" if r.get("ok") else "FAILED")
        print(f"LAN    : {r.get('lan')}")
        print(f"LAN IP : {r.get('lan_ip')}")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "forward-on":
        r = execute("router", "forward-on")
        print("IP forward:", "OK" if r.get("ok") else "FAILED")
        print(r.get("stdout", ""))
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "nat-up":
        r = execute("router", "nat-up")
        print("NAT up:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "nat-down":
        r = execute("router", "nat-down")
        print("NAT down:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "enable":
        r = execute("router", "enable")
        print("Router enable:", "OK" if r.get("ok") else "FAILED")
        for name, result in r.get("results", {}).items():
            print(f"  {name:<14}: {'OK' if result.get('ok') else 'FAILED'}")
            if result.get("stderr"):
                print(f"    {result.get('stderr')}")
        return

    if subcmd == "disable":
        r = execute("router", "disable")
        print("Router disable:", "OK" if r.get("ok") else "FAILED")
        for name, result in r.get("results", {}).items():
            print(f"  {name:<14}: {'OK' if result.get('ok') else 'FAILED'}")
            if result.get("stderr"):
                print(f"    {result.get('stderr')}")
        return

    r = execute("router", "status")
    print(f"State      : {r.get('state')}")
    print(f"Enabled    : {r.get('enabled')}")
    print(f"WAN        : {r.get('wan')}")
    print(f"LAN        : {r.get('lan')}")
    print(f"LAN IP     : {r.get('lan_ip')}")
    print(f"IP Forward : {r.get('ip_forward')}")
    print(f"DHCP       : {r.get('dhcp')}")
    print()
    print("Interfaces:")
    print(r.get("interfaces", ""))
    print()
    print("Routes:")
    print(r.get("routes", ""))

def cmd_firewall(subcmd="status"):
    print_header()

    if subcmd == "init":
        r = execute("firewall", "init")
        print("Firewall init:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "reset":
        r = execute("firewall", "reset")
        print("Firewall reset:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    fw = execute("firewall", "status")
    print(f"IPv4 Forward : {fw.get('ip_forward', '')}")
    print(f"NFT OK       : {fw.get('nft_ok', '')}")
    print()
    print("Ruleset:")
    rules = fw.get("nft_ruleset", "")
    print(rules if rules else "(empty)")

def cmd_network():
    print_header()
    n = execute("network", "status")
    print("Interfaces:")
    print(n.get("interfaces", ""))
    print()
    print("Routes:")
    print(n.get("routes", ""))
    print()
    print("DNS:")
    print(n.get("dns", ""))

def cmd_modules():
    print_header()
    mods = load_modules()
    if not mods:
        print("No modules loaded.")
        return

    print("Loaded modules:")
    for name, mod in sorted(mods.items()):
        version = getattr(mod, "VERSION", "-")
        display = getattr(mod, "NAME", name)
        print(f"  {display:<16} {version}")

def cmd_audit():
    print_header()
    rows = list_logs(20)
    if not rows:
        print("No audit logs.")
        return
    for row in rows:
        id_, ts, actor, action, detail = row
        print(f"{id_:>4}  {ts}  {actor:<8}  {action:<16}  {detail}")

def cmd_help():
    print_header()
    print("Usage:")
    print("  ninjaku status")
    print("  ninjaku status")
    print("  ninjaku status --json")
    print("  ninjaku audit")
    print("  ninjaku modules")
    print("  ninjaku network")
    print("  ninjaku firewall [status|init|reset]")
    print("  ninjaku router [status|lan-up|forward-on|nat-up|nat-down|enable|disable]")
    print("  ninjaku dhcp [status|start|stop]")
    print("  ninjaku config [list|set]")
    print("  ninjaku devices [sync|set-alias|set-notes|set-profile]")
    print("  ninjaku profiles")
    print("  ninjaku help")

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("help", "-h", "--help"):
        cmd_help()
        return

    if args[0] == "status":
        if len(args) > 1 and args[1] == "--json":
            cmd_status_json()
        else:
            cmd_status()
        return

    if args[0] == "audit":
        cmd_audit()
        return

    if args[0] == "modules":
        cmd_modules()
        return

    if args[0] == "network":
        cmd_network()
        return

    if args[0] == "firewall":
        subcmd = args[1] if len(args) > 1 else "status"
        cmd_firewall(subcmd)
        return

    if args[0] == "router":
        subcmd = args[1] if len(args) > 1 else "status"
        cmd_router(subcmd)
        return

    if args[0] == "dhcp":
        subcmd = args[1] if len(args) > 1 else "status"
        cmd_dhcp(subcmd)
        return

    if args[0] == "config":
        cmd_config(args[1:])
        return

    if args[0] == "devices":
        cmd_devices(args[1:])
        return

    if args[0] == "profiles":
        cmd_profiles()
        return

    print(f"Unknown command: {args[0]}")
    print("Run: ninjaku help")
    sys.exit(1)

if __name__ == "__main__":
    main()
