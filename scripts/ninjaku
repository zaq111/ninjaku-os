#!/usr/bin/env python3
import sys
import json
from pathlib import Path

sys.path.insert(0, "/opt/ninjaku")

from lib.modules import execute, load_modules
from lib.settings import list_all, set as set_setting
from core.audit import list_logs

VERSION = "1.0-alpha"

def print_header():
    print("Ninjaku OS Router")
    print(f"Version: {VERSION}")
    print()

def cmd_status():
    s = execute('system', 'status')
    print_header()
    print(f"Hostname : {s.get('hostname','')}")
    print(f"Kernel   : {s.get('kernel','')}")
    print(f"Uptime   : {s.get('uptime','')}")
    print()
    print("Interfaces:")
    print(s.get("ip", ""))
    print()
    failed = s.get("failed_units", "").strip()
    if failed:
        print("Failed units:")
        print(failed)
    else:
        print("Failed units: none")

def cmd_status_json():
    print(json.dumps(execute('system', 'status'), indent=2))














def cmd_dns_filter(args=None):
    print_header()
    args = args or []

    if not args:
        r = execute("dns_filter", "status")
        print(f"Blocked domains : {r.get('enabled_domains')}")
        print(f"Config          : {r.get('conf')}")
        print()
        for d in r.get("domains", [])[:30]:
            print(f"{d.get('domain'):<40} {d.get('list_name'):<12} {d.get('enabled')}")
        if len(r.get("domains", [])) > 30:
            print(f"... and {len(r.get('domains', [])) - 30} more")
        return

    if args[0] == "add":
        if len(args) < 2:
            print("Usage: ninjaku dns-filter add <domain>")
            return
        r = execute("dns_filter", "add", domain=args[1])
        print("DNS block add:", "OK" if r.get("ok") else "FAILED")
        print(f"Domain : {r.get('domain')}")
        return

    if args[0] == "delete":
        if len(args) < 2:
            print("Usage: ninjaku dns-filter delete <domain>")
            return
        r = execute("dns_filter", "delete", domain=args[1])
        print("DNS block delete:", "OK" if r.get("ok") else "FAILED")
        print(f"Domain  : {r.get('domain')}")
        print(f"Deleted : {r.get('deleted')}")
        return

    if args[0] == "import":
        if len(args) < 2:
            print("Usage: ninjaku dns-filter import <file> [list_name]")
            return
        list_name = args[2] if len(args) > 2 else "imported"
        r = execute("dns_filter", "import", path=args[1], list_name=list_name)
        print("DNS blocklist import:", "OK" if r.get("ok") else "FAILED")
        print(f"Imported : {r.get('imported')}")
        print(f"Skipped  : {r.get('skipped')}")
        print(f"List     : {r.get('list_name')}")
        return

    if args[0] == "apply":
        r = execute("dns_filter", "apply")
        print("DNS filter apply:", "OK" if r.get("ok") else "FAILED")
        print(f"Skipped : {r.get('skipped')}")
        print(f"State   : {r.get('state')}")
        print(f"Config  : {r.get('conf')}")
        return

    print("Usage:")
    print("  ninjaku dns-filter")
    print("  ninjaku dns-filter add <domain>")
    print("  ninjaku dns-filter delete <domain>")
    print("  ninjaku dns-filter import <file> [list_name]")
    print("  ninjaku dns-filter apply")

def cmd_leases(args=None):
    print_header()
    args = args or []

    if not args:
        r = execute("static_leases", "status")
        leases = r.get("leases", [])
        print(f"Static leases: {len(leases)}")
        print()
        print(f"{'IP':<16} {'MAC':<18} {'HOSTNAME':<20} {'ENABLED'}")
        for l in leases:
            print(f"{l.get('ip',''):<16} {l.get('mac',''):<18} {l.get('hostname',''):<20} {l.get('enabled')}")
        return

    if args[0] == "set":
        if len(args) < 3:
            print("Usage: ninjaku leases set <mac> <ip> [hostname]")
            return
        hostname = args[3] if len(args) > 3 else ""
        r = execute("static_leases", "set", mac=args[1], ip=args[2], hostname=hostname)
        print("Static lease set:", "OK" if r.get("ok") else "FAILED")
        print(f"MAC      : {r.get('mac')}")
        print(f"IP       : {r.get('ip')}")
        print(f"Hostname : {r.get('hostname')}")
        return

    if args[0] == "delete":
        if len(args) < 2:
            print("Usage: ninjaku leases delete <mac>")
            return
        r = execute("static_leases", "delete", mac=args[1])
        print("Static lease delete:", "OK" if r.get("ok") else "FAILED")
        print(f"MAC     : {r.get('mac')}")
        print(f"Deleted : {r.get('deleted')}")
        return

    if args[0] == "apply":
        r = execute("static_leases", "apply")
        print("Static leases apply:", "OK" if r.get("ok") else "FAILED")
        print(f"Config : {r.get('conf')}")
        return

    print("Usage:")
    print("  ninjaku leases")
    print("  ninjaku leases set <mac> <ip> [hostname]")
    print("  ninjaku leases delete <mac>")
    print("  ninjaku leases apply")

def cmd_api():
    print_header()
    r = execute("api", "status")
    print(f"Service : {r.get('service')}")
    print(f"Enabled : {r.get('enabled')}")
    print()
    print("Health:")
    print(r.get("health", ""))
    print()
    print("Listen:")
    for line in r.get("listen", "").splitlines():
        if ":8181" in line:
            print(line)

def cmd_policy(args=None):
    args = args or []
    print_header()

    if args and args[0] == "set":
        if len(args) < 4:
            print("Usage: ninjaku policy set <profile> <field> <value>")
            print("Fields: internet, bandwidth, dns_filter, schedule, priority")
            return

        r = execute("policy", "set", profile=args[1], field=args[2], value=" ".join(args[3:]))
        print("Policy update:", "OK" if r.get("ok") else "FAILED")
        if r.get("error"):
            print(r.get("error"))
        else:
            print(f"{r.get('profile')} {r.get('field')} = {r.get('value')}")
        return

    if args and args[0] == "resolve":
        if len(args) < 2:
            print("Usage: ninjaku policy resolve <mac-or-profile>")
            return

        target = args[1]
        if ":" in target:
            r = execute("policy", "resolve", mac=target)
        else:
            r = execute("policy", "resolve", profile=target)

        print(f"Profile   : {r.get('profile')}")
        print(f"Internet  : {r.get('internet')}")
        print(f"Bandwidth : {r.get('bandwidth')}")
        print(f"DNS       : {r.get('dns_filter')}")
        print(f"Schedule  : {r.get('schedule')}")
        print(f"Priority  : {r.get('priority')}")
        return

    if args and args[0] == "apply":
        r = execute("policy", "apply")
        print("Policy apply:", "OK" if r.get("ok") else "FAILED")
        print(f"Blocked devices: {r.get('blocked_count', 0)}")
        for dev in r.get("blocked", []):
            print(f"  {dev.get('ip')} {dev.get('mac')} {dev.get('hostname')}")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    r = execute("policy", "status")
    policies = r.get("policies", [])

    print(f"{'PROFILE':<12} {'INTERNET':<10} {'BANDWIDTH':<12} {'DNS':<10} {'SCHEDULE':<10} {'PRIORITY'}")
    for p in policies:
        print(
            f"{p.get('profile'):<12} "
            f"{p.get('internet'):<10} "
            f"{p.get('bandwidth'):<12} "
            f"{p.get('dns_filter'):<10} "
            f"{p.get('schedule'):<10} "
            f"{p.get('priority')}"
        )

def cmd_profiles(args=None):
    args = args or []
    print_header()

    if args and args[0] == "add":
        if len(args) < 2:
            print("Usage: ninjaku profiles add <name> [description]")
            return
        name = args[1]
        description = " ".join(args[2:]) if len(args) > 2 else ""
        r = execute("profiles", "add", name=name, description=description)
        print("Add profile:", "OK" if r.get("ok") else "FAILED")
        if r.get("error"):
            print(r.get("error"))
        return

    if args and args[0] in ("delete", "del", "remove"):
        if len(args) < 2:
            print("Usage: ninjaku profiles delete <name>")
            return
        r = execute("profiles", "delete", name=args[1])
        print("Delete profile:", "OK" if r.get("ok") else "FAILED")
        if r.get("error"):
            print(r.get("error"))
        return

    r = execute("profiles", "status")
    profiles = r.get("profiles", [])

    print("Profiles:")
    for p in profiles:
        kind = "system" if p.get("is_system") else "custom"
        print(f"  {p.get('name'):<12} {kind:<8} {p.get('description')}")

def cmd_devices(args=None):
    args = args or []
    print_header()

    if args and args[0] == "sync":
        r = execute("devices", "sync")
        print("Devices sync:", "OK" if r.get("ok") else "FAILED")
        print(f"Lease count : {r.get('lease_count', r.get('count', 0))}")
        print(f"Neighbor count : {r.get('neighbor_count', 0)}")
        return

    if args and args[0] == "cleanup-wan":
        r = execute("devices", "cleanup-wan")
        print("Cleanup WAN devices:", "OK" if r.get("ok") else "FAILED")
        print(f"LAN prefix : {r.get('lan_prefix')}")
        print(f"Deleted    : {r.get('deleted')}")
        return

    if args and args[0] == "mark-offline":
        minutes = int(args[1]) if len(args) > 1 else 5
        r = execute("devices", "mark-offline", minutes=minutes)
        print("Mark offline:", "OK" if r.get("ok") else "FAILED")
        print(f"Threshold : {r.get('minutes')} minutes")
        print(f"Changed   : {r.get('changed')}")
        return

    if args and args[0] in ("set-alias", "set-notes", "set-profile"):
        if len(args) < 3:
            print(f"Usage: ninjaku devices {args[0]} <mac> <value>")
            return
        r = execute("devices", args[0], mac=args[1], value=" ".join(args[2:]))
        print("Update:", "OK" if r.get("ok") else "FAILED")
        if not r.get("ok"):
            print(r.get("error", "unknown error"))
        else:
            print(f"{r.get('mac')} {r.get('field')} = {r.get('value')}")
            pa = r.get("policy_applied")
            if pa is not None:
                print("Policy apply:", "OK" if pa.get("ok") else "FAILED")
                print(f"Blocked devices: {pa.get('blocked_count', 0)}")
        return

    d = execute("devices", "status")
    devices = d.get("devices", [])

    print(f"Devices: {d.get('count', 0)}")
    print()

    if not devices:
        print("(empty)")
        return

    print(f"{'IP':<16} {'MAC':<18} {'STATUS':<8} {'PROFILE':<10} {'NET':<8} {'BW':<10} {'SEEN'}")
    for dev in devices:
        print(
            f"{dev.get('ip',''):<16} "
            f"{dev.get('mac',''):<18} "
            f"{dev.get('status',''):<8} "
            f"{dev.get('profile',''):<10} "
            f"{dev.get('policy_internet',''):<8} "
            f"{dev.get('policy_bandwidth',''):<10} "
            f"{dev.get('seen_count','')}"
        )

def cmd_config(args):
    print_header()

    if not args or args[0] == "list":
        rows = list_all()
        if not rows:
            print("No settings.")
            return
        for k, v in rows:
            print(f"{k:<24} {v}")
        return

    if args[0] == "set" and len(args) >= 3:
        key = args[1]
        value = " ".join(args[2:])
        set_setting(key, value)
        print(f"Set {key} = {value}")
        return

    print("Usage:")
    print("  ninjaku config list")
    print("  ninjaku config set <key> <value>")

def cmd_dhcp(subcmd="status"):
    print_header()

    if subcmd == "start":
        r = execute("dhcp", "start")
        print("DHCP start:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "stop":
        r = execute("dhcp", "stop")
        print("DHCP stop:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    d = execute("dhcp", "status")
    print(f"Service : {d.get('service')}")
    print(f"Enabled : {d.get('enabled')}")
    print()
    print("Config:")
    print(d.get("config") or "(missing)")
    print()
    print("Leases:")
    print(d.get("leases") or "(empty)")

def cmd_router(subcmd="status"):
    print_header()

    if subcmd == "lan-up":
        r = execute("router", "lan-up")
        print("LAN up:", "OK" if r.get("ok") else "FAILED")
        print(f"LAN    : {r.get('lan')}")
        print(f"LAN IP : {r.get('lan_ip')}")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "forward-on":
        r = execute("router", "forward-on")
        print("IP forward:", "OK" if r.get("ok") else "FAILED")
        print(r.get("stdout", ""))
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "nat-up":
        r = execute("router", "nat-up")
        print("NAT up:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "nat-down":
        r = execute("router", "nat-down")
        print("NAT down:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "enable":
        r = execute("router", "enable")
        print("Router enable:", "OK" if r.get("ok") else "FAILED")
        for name, result in r.get("results", {}).items():
            print(f"  {name:<14}: {'OK' if result.get('ok') else 'FAILED'}")
            if result.get("stderr"):
                print(f"    {result.get('stderr')}")
        return

    if subcmd == "disable":
        r = execute("router", "disable")
        print("Router disable:", "OK" if r.get("ok") else "FAILED")
        for name, result in r.get("results", {}).items():
            print(f"  {name:<14}: {'OK' if result.get('ok') else 'FAILED'}")
            if result.get("stderr"):
                print(f"    {result.get('stderr')}")
        return

    r = execute("router", "status")
    print(f"State      : {r.get('state')}")
    print(f"Enabled    : {r.get('enabled')}")
    print(f"WAN        : {r.get('wan')} ({r.get('wan_state', 'unknown')})")
    print(f"LAN        : {r.get('lan')} ({r.get('lan_state', 'unknown')})")
    print(f"LAN IP     : {r.get('lan_ip')}")
    print(f"IP Forward : {r.get('ip_forward')}")
    print(f"DHCP       : {r.get('dhcp')}")
    print()
    print("Interfaces:")
    print(r.get("interfaces", ""))
    print()
    print("Routes:")
    print(r.get("routes", ""))

def cmd_firewall(subcmd="status"):
    print_header()

    if subcmd == "init":
        r = execute("firewall", "init")
        print("Firewall init:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "reset":
        r = execute("firewall", "reset")
        print("Firewall reset:", "OK" if r.get("ok") else "FAILED")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    if subcmd == "apply-policy":
        r = execute("firewall", "apply-policy")
        print("Firewall apply policy:", "OK" if r.get("ok") else "FAILED")
        print(f"Blocked devices: {r.get('blocked_count', 0)}")
        for dev in r.get("blocked", []):
            print(f"  {dev.get('ip')} {dev.get('mac')} {dev.get('hostname')}")
        if r.get("stderr"):
            print(r.get("stderr"))
        return

    fw = execute("firewall", "status")
    print(f"IPv4 Forward : {fw.get('ip_forward', '')}")
    print(f"NFT OK       : {fw.get('nft_ok', '')}")
    print()
    print("Ruleset:")
    rules = fw.get("nft_ruleset", "")
    print(rules if rules else "(empty)")

def cmd_network():
    print_header()
    n = execute("network", "status")
    print("Interfaces:")
    print(n.get("interfaces", ""))
    print()
    print("Routes:")
    print(n.get("routes", ""))
    print()
    print("DNS:")
    print(n.get("dns", ""))

def cmd_modules():
    print_header()
    mods = load_modules()
    if not mods:
        print("No modules loaded.")
        return

    print("Loaded modules:")
    for name, mod in sorted(mods.items()):
        version = getattr(mod, "VERSION", "-")
        display = getattr(mod, "NAME", name)
        print(f"  {display:<16} {version}")

def cmd_audit():
    print_header()
    rows = list_logs(20)
    if not rows:
        print("No audit logs.")
        return
    for row in rows:
        id_, ts, actor, action, detail = row
        print(f"{id_:>4}  {ts}  {actor:<8}  {action:<16}  {detail}")

def cmd_module_passthrough(module, args=None):
    args = args or []
    command = args[0] if args else "status"
    kwargs = {}

    # simple key=value support
    for item in args[1:]:
        if "=" in item:
            k, v = item.split("=", 1)
            kwargs[k] = v

    try:
        r = execute(module, command, **kwargs)
        print_header()
        print(json.dumps(r, indent=2))
    except Exception as e:
        print_header()
        print(f"{module} {command}: FAILED")
        print(str(e))
        sys.exit(1)

def cmd_help():
    print_header()
    print("Usage:")
    print("  ninjaku status")
    print("  ninjaku status")
    print("  ninjaku status --json")
    print("  ninjaku audit")
    print("  ninjaku modules")
    print("  ninjaku network")
    print("  ninjaku firewall [status|init|reset|apply-policy]")
    print("  ninjaku router [status|lan-up|forward-on|nat-up|nat-down|enable|disable]")
    print("  ninjaku dhcp [status|start|stop]")
    print("  ninjaku config [list|set]")
    print("  ninjaku devices [sync|cleanup-wan|mark-offline|set-alias|set-notes|set-profile]")
    print("  ninjaku leases [set|delete|apply]")
    print("  ninjaku dns-filter [add|delete|import|apply]")
    print("  ninjaku profiles [add|delete]")
    print("  ninjaku policy [set|resolve|apply]")
    print("  ninjaku qos [status|apply|clear]")
    print("  ninjaku wifi [status|start|stop|restart|stations]")
    print("  ninjaku adguard [status]")
    print("  ninjaku packages [status|install|remove] package=<name>")
    print("  ninjaku tailscale [status]")
    print("  ninjaku wireguard [status]")
    print("  ninjaku api")
    print("  ninjaku help")

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("help", "-h", "--help"):
        cmd_help()
        return

    if args[0] == "status":
        if len(args) > 1 and args[1] == "--json":
            cmd_status_json()
        else:
            cmd_status()
        return

    if args[0] == "audit":
        cmd_audit()
        return

    if args[0] == "modules":
        cmd_modules()
        return

    if args[0] == "network":
        cmd_network()
        return

    if args[0] == "firewall":
        subcmd = args[1] if len(args) > 1 else "status"
        cmd_firewall(subcmd)
        return

    if args[0] == "router":
        subcmd = args[1] if len(args) > 1 else "status"
        cmd_router(subcmd)
        return

    if args[0] == "dhcp":
        subcmd = args[1] if len(args) > 1 else "status"
        cmd_dhcp(subcmd)
        return

    if args[0] == "config":
        cmd_config(args[1:])
        return

    if args[0] == "devices":
        cmd_devices(args[1:])
        return

    if args[0] == "leases":
        cmd_leases(args[1:])
        return

    if args[0] == "dns-filter":
        cmd_dns_filter(args[1:])
        return

    if args[0] == "profiles":
        cmd_profiles(args[1:])
        return

    if args[0] == "policy":
        cmd_policy(args[1:])
        return

    if args[0] in ("qos", "wifi", "adguard", "packages", "tailscale", "wireguard"):
        cmd_module_passthrough(args[0], args[1:])
        return

    if args[0] == "api":
        cmd_api()
        return

    print(f"Unknown command: {args[0]}")
    print("Run: ninjaku help")
    sys.exit(1)

if __name__ == "__main__":
    main()
